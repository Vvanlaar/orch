# Server
PORT=3011
DASHBOARD_PORT=3010

# GitHub
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_TOKEN=ghp_your-token

# Azure DevOps
ADO_ORG=bluebillywig
ADO_PAT=your-pat
# For Testing Assignment feature (optional)
ADO_PROJECT=BBNew
ADO_TEAM=Core
ADO_REVIEWED_BY_FIELD=Custom.ReviewedBy

# Claude
MAX_CONCURRENT_TASKS=2
CLAUDE_TIMEOUT=300000
# Terminal preference: auto, wt, cmd, powershell, pwsh, git-bash
# PREFERRED_TERMINAL=auto

# Repos
REPOS_BASE_DIR=../
REPOS_AUTO_SCAN=true
# Manual mapping (optional, merged with auto-scanned repos)
# REPOS_MAPPING={"owner/repo-name": "local-folder-name"}

# Polling (no ngrok needed)
POLLING_ENABLED=true
POLLING_INTERVAL_MS=60000
