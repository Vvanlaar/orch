{
  "name": "orch",
  "version": "0.1.11",
  "description": "Event-driven Claude Code orchestrator for GitHub and Azure DevOps",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:dashboard": "vite src/dashboard",
    "clean": "rm -rf dist",
    "build": "tsc && pnpm run build:dashboard",
    "rebuild": "pnpm run clean && pnpm run build",
    "build:dashboard": "vite build src/dashboard",
    "start": "node dist/server/index.js",
    "test": "vitest",
    "migrate": "tsx src/core/db/migrate.ts",
    "dev": "concurrently --kill-others \"pnpm:dev:server\" \"pnpm:dev:dashboard\"",
    "postinstall": "pnpm exec playwright install chromium",
    "build:desktop": "pnpm run build && cp -r dist/server dist/core dist/dashboard desktop/ && cd desktop && pnpm install && pnpm exec electron-builder --win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "@types/cors": "^2.8.19",
    "chalk": "^5.3.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.2",
    "octokit": "^4.1.0",
    "playwright": "^1.49.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.11",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.2.1",
    "flowbite": "^4.0.1",
    "flowbite-svelte": "^1.31.0",
    "flowbite-svelte-icons": "^3.1.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "playwright",
      "esbuild",
      "electron",
      "electron-winstaller"
    ]
  }
}
